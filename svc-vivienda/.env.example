# svc-vivienda — Variables de entorno para desarrollo local
# Copiar como .env y completar los valores

DATABASE_URL=postgresql+asyncpg://user_vivienda:devpassword@localhost:5432/db_vivienda
GCP_PROJECT_ID=gestorcooperativo
SERVICE_NAME=svc-vivienda
ENVIRONMENT=development
PUBSUB_TOPIC_VIVIENDA=ministerio-eventos-vivienda
GOOGLE_JWKS_URI=https://www.googleapis.com/oauth2/v3/certs
GOOGLE_ISSUER=https://accounts.google.com

# Sync checklist técnico Cordón Cuneta (Google Sheet "Base TOTAL")
# El Sheet debe compartirse como Viewer con la SA de runtime del servicio.
GOOGLE_SHEET_CC_ID=
GOOGLE_SHEET_CC_RANGE=Base TOTAL!A6:AR400
